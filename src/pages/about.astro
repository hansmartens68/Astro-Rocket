---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import TechStack from '@/components/landing/TechStack.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
---

<PageLayout
  title="About Astro Rocket — Astro 6 Starter Theme"
  description="Astro Rocket is a production-ready Astro 6 starter theme with 57+ components, 7 color themes, built-in i18n, dark mode, and a perfect Lighthouse score."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand">About the theme</Badge>

     <h1 slot="title">
<span class="bg-brand-500 mt-2 inline-block rounded-lg px-3 py-1 text-white"
          >Astro Rocket —</span> <br />
Fast. Accessible. Yours.
</h1>

    <p slot="description">
      Astro Rocket is built around the details that actually matter — speed,
      accessibility, and a design system that scales. Here's what's under the hood.
    </p>
  </Hero>

  <!-- Background -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2 items-center">

        <!-- Left: story -->
        <div>
          <Badge variant="brand" pill class="mb-6">The story</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-6">
            One starter.<br />
            <span class="text-brand-500">Every tool you need.</span>
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed mb-4">
            Astro Rocket started as a personal toolkit — a collection of patterns, components, and configuration that kept getting reused across projects. Over time it grew into a complete, opinionated starter that handles all the hard parts of launching a modern website.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed mb-8">
            The goal was simple: clone it and start on the real work immediately. No stitching together packages, no fighting with configuration, no performance retrofit later. Everything — design system, i18n, dark mode, SEO — is baked in from day one.
          </p>
          <Button variant="outline" href="/projects">
            See what it can do
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>

        <!-- Right: at a glance card -->
        <div>
          <Card variant="elevated" padding="lg">
            <p class="text-xs font-bold tracking-widest uppercase text-foreground-muted mb-6">At a glance</p>
            <dl class="divide-y divide-border">
              {[
                { icon: 'brand-astro', label: 'Built on', value: 'Astro 6' },
                { icon: 'layout-grid', label: 'Components', value: '57+' },
                { icon: 'palette', label: 'Color themes', value: '7 beautiful themes' },
                { icon: 'globe', label: 'i18n', value: 'Multi-language ready' },
                { icon: 'shield-check', label: 'License', value: 'MIT — free to use anywhere' },
              ].map(({ icon, label, value }) => (
                <div class="flex items-center gap-4 py-4">
                  <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                    <Icon name={icon} size="sm" />
                  </div>
                  <div class="flex-1 min-w-0 flex items-baseline justify-between gap-4">
                    <dt class="text-sm text-foreground-muted shrink-0">{label}</dt>
                    <dd class="text-sm font-semibold text-foreground text-right">{value}</dd>
                  </div>
                </div>
              ))}
            </dl>
          </Card>
        </div>

      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-[var(--space-section-header)] text-center">
        <Badge variant="brand" pill class="mb-4">Our values</Badge>
        <h2 class="font-display text-4xl font-bold text-foreground mb-4">
          Built on These Principles
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          These aren't goals to work toward — they're constraints every component, pattern, and default in Astro Rocket is held to.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="zap" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Performance First</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Ships with a 100/100 Lighthouse score and keeps it there. Static HTML output,
                no unused scripts, and image handling that won't drag your metrics down.
              </p>
            </div>
          </div>
        </Card>

        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="minimize-2" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Keep It Simple</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Clean architecture, minimal dependencies, and readable code. Easy to
                understand, extend, and maintain as your project grows.
              </p>
            </div>
          </div>
        </Card>

        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="eye" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Accessible by Default</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Semantic HTML, keyboard navigation, and WCAG compliance come standard.
                Accessibility is never an afterthought in Astro Rocket.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- The Partnership -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div>
          <Badge variant="brand" pill class="mb-6">The Partnership</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-2">
            Astro Rocket
          </h2>
          <p class="text-lg text-brand-500 font-medium mb-6">Web Designer &amp; Developer</p>
          <p class="text-lg text-foreground-muted leading-relaxed mb-8">
            16 years of craft — design, code, performance, and honest communication. Based in Veghel, working worldwide.
          </p>
          <div class="flex flex-wrap gap-2">
            <Badge variant="brand" pill>Astro</Badge>
            <Badge variant="brand" pill>Tailwind</Badge>
            <Badge variant="brand" pill>TypeScript</Badge>
          </div>
        </div>

        <Card variant="elevated" padding="lg">
          <p class="text-xs font-bold tracking-widest uppercase text-foreground-muted mb-6">At a glance</p>
          <dl class="divide-y divide-border">
            {[
              { icon: 'history', label: 'Experience', value: '16 years' },
              { icon: 'map-pin', label: 'Based in', value: 'Veghel, Netherlands' },
              { icon: 'globe', label: 'Working', value: 'Worldwide' },
              { icon: 'zap', label: 'Focus', value: 'Design, code & performance' },
            ].map(({ icon, label, value }) => (
              <div class="flex items-center gap-4 py-4">
                <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name={icon} size="sm" />
                </div>
                <div class="flex-1 min-w-0 flex items-baseline justify-between gap-4">
                  <dt class="text-sm text-foreground-muted shrink-0">{label}</dt>
                  <dd class="text-sm font-semibold text-foreground text-right">{value}</dd>
                </div>
              </div>
            ))}
          </dl>
        </Card>
      </div>
    </div>
  </section>

  <!-- My Stack -->
  <TechStack
    badge="The Stack"
    title="The Stack"
    description="The tools Astro Rocket is built on — chosen for performance, an excellent developer experience, and long-term reliability."
  />

  <!-- CTA -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <Badge variant="brand" pill class="mb-4">Get started</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4">
        Ready to build?
      </h2>
      <p class="text-lg text-foreground-muted mb-8">
        Astro Rocket is free, open-source, and ready to clone. Start building
        something you're proud of.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="https://github.com/hansmartens68/astro-rocket">
          <Icon name="github" size="sm" />
          Get it on GitHub
        </Button>
        <Button size="lg" variant="outline" href="/blog" class="border-border-strong">
          Read the Blog
        </Button>
      </div>
    </div>
  </section>

  <!-- Follow Along -->
  <CTA variant="default" size="md" maxWidth="lg" class="bg-background-secondary">
    <Badge slot="logo" variant="brand" pill>Stay updated</Badge>
    <h2 slot="heading" class="!text-4xl">Follow along</h2>
    <p slot="description" class="!text-lg">Stay in the loop — new articles, thoughts, and updates.</p>

    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="/rss.xml"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
      >
        <Icon name="rss" size="sm" />
        RSS Feed
      </a>
      <a
        href="https://x.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
      >
        <Icon name="x-twitter" size="sm" />
        X / Twitter
      </a>
      <a
        href="https://linkedin.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
      >
        <Icon name="linkedin" size="sm" />
        LinkedIn
      </a>
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
      >
        <Icon name="github" size="sm" />
        GitHub
      </a>
      <a
        href="mailto:hello@youremail.com"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
      >
        <Icon name="mail" size="sm" />
        Email
      </a>
    </div>
  </CTA>
</PageLayout>
