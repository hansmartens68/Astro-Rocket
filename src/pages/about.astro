---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import TechStack from '@/components/landing/TechStack.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
---

<PageLayout
  title="About Astro Rocket — Web Designer & Developer | Veghel"
  description="Astro Rocket is a web designer and developer based in Veghel, the Netherlands. I build fast, modern websites and write about design and development."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand">About me</Badge>

<h1 slot="title">
Astro Rocket —<br />
<span class="text-brand-500">Web Designer & Developer</span>
</h1>

    <p slot="description">
      I care about both sides of the craft — how a site looks and how it
      performs. Here's a bit more about how I think and work.
    </p>
  </Hero>

  <!-- Background -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2 items-center">

        <!-- Left: story -->
        <div>
          <h2 class="font-display text-4xl font-bold text-foreground mb-6">
            Design and code,<br />under one roof.
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed mb-4">
            It started with graphic design — layouts, typography, visual identity. Over time, curiosity about how things actually get built on the web led to front-end development, and eventually to full-stack work. Sixteen years later, both disciplines live in the same head and get applied to every project.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed mb-8">
            Working with a single designer-developer means no handoffs, no miscommunication between two separate teams, and no gap between how something looks and how it gets built. From the first wireframe to the final deployment — it's one continuous process.
          </p>
          <Button variant="outline" href="/projects">
            See my work
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>

        <!-- Right: at a glance card -->
        <div>
          <Card variant="elevated">
            <p class="text-xs font-bold tracking-wide uppercase text-foreground-muted mb-5">At a glance</p>
            <dl class="divide-y divide-border">
              {[
                { icon: 'calendar', label: 'In the field since', value: '2008' },
                { icon: 'map-pin', label: 'Based in', value: 'Veghel, Netherlands' },
                { icon: 'globe', label: 'Clients', value: 'Worldwide' },
                { icon: 'user', label: 'Studio type', value: 'Independent — one point of contact' },
                { icon: 'layers', label: 'Disciplines', value: 'Design & Development' },
              ].map(({ icon, label, value }) => (
                <div class="flex items-center gap-4 py-3.5">
                  <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                    <Icon name={icon} size="sm" />
                  </div>
                  <div class="flex-1 min-w-0 flex items-baseline justify-between gap-4">
                    <dt class="text-sm text-foreground-muted shrink-0">{label}</dt>
                    <dd class="text-sm font-semibold text-foreground text-right">{value}</dd>
                  </div>
                </div>
              ))}
            </dl>
          </Card>
        </div>

      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="font-display text-4xl font-bold text-foreground mb-[var(--space-section-header)] text-center">
        How I Work
      </h2>

      <div class="grid gap-8 md:grid-cols-3">
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="zap" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Performance First</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Fast sites rank better, convert better, and keep users happy. I optimise for
                speed from the ground up — not as an afterthought.
              </p>
            </div>
          </div>
        </Card>

        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="minimize-2" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Keep It Simple</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                The best solution is usually the simplest one. I avoid unnecessary complexity
                so your site is easy to maintain and grow.
              </p>
            </div>
          </div>
        </Card>

        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="message-circle" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Clear Communication</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                No jargon, no surprises. I keep you in the loop at every stage and respond
                within one business day.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- My Stack -->
  <TechStack
    title="My Stack"
    description="The tools I rely on every day to build fast, modern websites — chosen for performance, great developer experience, and reliability."
  />

  <!-- CTA -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="font-display text-4xl font-bold text-foreground mb-4">
        Ready to work together?
      </h2>
      <p class="text-lg text-foreground-muted mb-8">
        I'm available for new projects. Let's talk about what you need.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href="/contact">
          Start a Project
          <Icon name="arrow-right" size="sm" />
        </Button>
        <Button size="lg" variant="outline" href="/blog" class="border-border-strong">
          Read the Blog
        </Button>
      </div>
    </div>
  </section>

  <!-- Follow Along -->
  <CTA variant="default" size="md" maxWidth="lg" class="bg-background-secondary">
    <h2 slot="heading" class="!text-4xl">Follow along</h2>
    <p slot="description" class="!text-lg">Stay in the loop — new articles, thoughts, and updates.</p>

    <div class="flex flex-wrap items-center justify-center gap-3">
      <a
        href="/rss.xml"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
      >
        <Icon name="rss" size="sm" />
        RSS Feed
      </a>
      <a
        href="https://x.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
      >
        <Icon name="x-twitter" size="sm" />
        X / Twitter
      </a>
      <a
        href="https://linkedin.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
      >
        <Icon name="linkedin" size="sm" />
        LinkedIn
      </a>
      <a
        href="https://github.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-brand-500 hover:text-brand-500"
      >
        <Icon name="github" size="sm" />
        GitHub
      </a>
    </div>
  </CTA>
</PageLayout>
