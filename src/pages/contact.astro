---
/**
 * Contact page
 * URL: /contact
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import { Hero } from '@/components/hero';

const channels = [
  {
    icon: 'linkedin',
    label: 'LinkedIn',
    value: 'linkedin.com',
    note: 'Connect professionally',
    href: 'https://linkedin.com',
    external: true,
  },
  {
    icon: 'github',
    label: 'GitHub',
    value: 'github.com',
    note: 'See what I\'m building',
    href: 'https://github.com',
    external: true,
  },
  {
    icon: 'x-twitter',
    label: 'X / Twitter',
    value: 'x.com',
    note: 'Follow for updates',
    href: 'https://x.com',
    external: true,
  },
];
---

<PageLayout
  title="Contact Astro Rocket — Start a Project | Veghel"
  description="Get in touch with Astro Rocket, web designer and developer based in Veghel, the Netherlands. Available for new projects."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand">Available for projects</Badge>

    <h1 slot="title">
      Let's <span class="text-brand-500">work together.</span>
    </h1>

    <p slot="description">
      Pick a channel and reach out. I'll get back to you within 1 business day.
    </p>
  </Hero>

  <!-- Contact Section -->
  <section class="pt-8 pb-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-3xl px-6">

      <!-- 2×2 contact grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {channels.map((ch) => (
          <a
            href={ch.href}
            {...ch.external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
            class="block group"
          >
            <Card hover padding="md" class="h-full">
              <div class="flex flex-col gap-4">
                <div class="flex items-center justify-between">
                  <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500">
                    <Icon name={ch.icon} size="md" />
                  </div>
                  <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors" />
                </div>
                <div>
                  <p class="text-xs text-foreground-muted mb-0.5">{ch.note}</p>
                  <p class="font-semibold text-foreground">{ch.label}</p>
                  <p class="text-sm text-foreground-muted truncate mt-0.5">{ch.value}</p>
                </div>
              </div>
            </Card>
          </a>
        ))}
      </div>

      <!-- Location card -->
      <div class="mt-4">
        <Card padding="md" class="bg-brand-500/5 border-brand-500/20">
          <div class="flex items-start gap-3">
            <Icon name="map-pin" size="md" class="text-brand-500 shrink-0 mt-0.5" />
            <div>
              <p class="font-semibold text-foreground">London, UK</p>
              <p class="text-sm text-foreground-muted mt-1">
                Remote worldwide. In-person available locally.
              </p>
            </div>
          </div>
        </Card>
      </div>

    </div>
  </section>
</PageLayout>
