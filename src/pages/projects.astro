---
/**
 * Projects page
 * URL: /projects
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import { getCollection } from 'astro:content';

const items = await getCollection('projects');
const projects = items.sort((a, b) => a.data.order - b.data.order);

const featured = projects.find((p) => p.data.featured);
const rest = projects.filter((p) => !p.data.featured);
---

<PageLayout
  title="Projects — Astro Rocket"
  description="Selected work — websites, tools, and open-source projects built by Astro Rocket."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand">
      <Icon name="layers" size="sm" />
      Selected work
    </Badge>

    <h1 slot="title">Projects</h1>

    <p slot="description">
      Example projects built with Astro Rocket.
    </p>
  </Hero>

  <!-- Featured project -->
  {featured && (
    <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
      <div class="mx-auto max-w-6xl px-6">
        <p class="text-brand-500 mb-6 text-sm font-bold tracking-wide uppercase">Featured</p>
        <Card variant="elevated" hover class="overflow-hidden !p-0">
          <div class="h-40 bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center">
            <Icon name="monitor" size="xl" class="text-brand-500 opacity-40" />
          </div>
          <div class="p-6">
            <h3 class="font-semibold text-foreground mb-2">
              {featured.data.title}
              {featured.data.year && (
                <span class="text-xs text-foreground-muted font-normal ml-2">{featured.data.year}</span>
              )}
            </h3>
            <p class="text-sm text-foreground-muted leading-relaxed mb-4">{featured.data.description}</p>
            <div class="flex flex-wrap gap-2 mb-4">
              {featured.data.tags.map((tag) => (
                <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">{tag}</span>
              ))}
            </div>
            <div class="flex flex-wrap gap-4">
              {featured.data.url && (
                <a href={featured.data.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors">
                  View project <Icon name="arrow-right" size="sm" />
                </a>
              )}
              {featured.data.repo && (
                <a href={featured.data.repo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors">
                  <Icon name="github" size="sm" /> Source code
                </a>
              )}
            </div>
          </div>
        </Card>
      </div>
    </section>
  )}

  <!-- All other projects -->
  {rest.length > 0 && (
    <section class="py-[var(--space-section-md)] border-t border-border">
      <div class="mx-auto max-w-6xl px-6">
        {featured && (
          <h2 class="font-display text-foreground mb-[var(--space-section-header)] text-2xl font-bold">
            More projects
          </h2>
        )}

        <div class="grid gap-6 md:grid-cols-2">
          {rest.map((project) => (
            <Card variant="elevated" hover class="overflow-hidden !p-0">
              <div class="h-40 bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center">
                <Icon name="box" size="xl" class="text-brand-500 opacity-40" />
              </div>
              <div class="p-6">
                <h3 class="font-semibold text-foreground mb-2">
                  {project.data.title}
                  {project.data.year && (
                    <span class="text-xs text-foreground-muted font-normal ml-2">{project.data.year}</span>
                  )}
                </h3>
                <p class="text-sm text-foreground-muted leading-relaxed mb-4">{project.data.description}</p>
                <div class="flex flex-wrap gap-2 mb-4">
                  {project.data.tags.map((tag) => (
                    <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">{tag}</span>
                  ))}
                </div>
                {(project.data.url ?? project.data.repo) && (
                  <a href={project.data.url ?? project.data.repo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors">
                    View project <Icon name="arrow-right" size="sm" />
                  </a>
                )}
              </div>
            </Card>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="font-display text-4xl font-bold text-foreground mb-4">
        Build something with Astro&nbsp;Rocket.
      </h2>
      <p class="text-lg text-foreground-muted mb-8">
        Clone the theme, swap in your own projects, and ship a site you're proud&nbsp;of.
      </p>
      <Button size="lg" href="https://github.com/hansmartens68/astro-rocket">
        <Icon name="github" size="sm" />
        Get it on GitHub
      </Button>
    </div>
  </section>
</PageLayout>
