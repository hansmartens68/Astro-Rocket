---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);
---

<LandingLayout
  title="Astro Rocket — Astro 6 starter theme"
  description="Astro 6 starter theme, with lots of components, built-in i18n, dark mode and everything you need to create a fast, modern website.
    </p>"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="centered" size="xl">
    <Badge slot="badge" variant="brand" pulse>Open Source · MIT Licensed</Badge>

    <h1 slot="title">
<span class="bg-brand-500 mt-2 inline-block rounded-lg px-3 py-1 text-white"
          >Astro Rocket —</span> <br />
Launch Fast. Look Great.
</h1>

    <p slot="description">
      A production-ready Astro 6 starter with 7 beautiful themes, 57+ components, built-in i18n, dark mode and a fast, modern foundation to build anything on.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href="https://github.com">
        <Icon name="github" size="sm" />
        Get it on GitHub
      </Button>
      <Button size="lg" variant="outline" href="#pricing">
        View Pricing
        <Icon name="chevron-down" size="sm" />
      </Button>
    </Fragment>
  </Hero>

  <!-- Services Section -->
  <section class="pt-[var(--space-section-sm)] pb-[var(--space-section-lg)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <Badge variant="brand" pill class="mb-4">Features</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          What's Included
        </h2>
        <p class="mt-4 text-lg text-foreground-muted max-w-2xl mx-auto">
          Everything you need to build a fast, modern website — design system, components, and
          developer tooling, all in one theme.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <!-- Web Design -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="layout" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Design System</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Seven color themes, consistent typography, and 57+ polished components — a
                complete design system ready to make your own.
              </p>
            </div>
          </div>
        </Card>

        <!-- Web Development -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="code" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Web Development</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Fast, accessible websites built with modern tooling. Astro, Tailwind, and
                best-practice architecture from day one.
              </p>
            </div>
          </div>
        </Card>

        <!-- Performance -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="zap" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Performance Built In</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Optimised for real-world speed from the ground up. Lean HTML output, top Core
                Web Vitals, and a Lighthouse score that holds in production.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- About Teaser -->
  <section class="py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div>
          <Badge variant="brand" pill class="mb-6">About the theme</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-6">
            Fast, accessible,<br />
            <span class="text-brand-500">and built to launch.</span>
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed mb-4">
            Astro Rocket is built around the details that actually matter — a perfect Lighthouse
            score, accessibility baked in from the start, and a design system that scales with
            your content instead of getting in the way.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed mb-8">
            Whether you're launching a portfolio, a product site, or a content-driven blog —
            Astro Rocket gives you the foundation to ship something you're proud of.
          </p>
          <Button variant="outline" href="/about">
            Explore the Theme
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>

        <Card variant="elevated" padding="lg">
          <p class="font-semibold text-sm text-foreground text-center">Astro Rocket — by the numbers</p>
          <p class="text-sm text-foreground-muted mt-0.5 mb-5 text-center">What the theme delivers out of the box.</p>
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-background-secondary rounded-xl p-5 flex flex-col items-center text-center gap-2 border-t-2 border-brand-500/40">
              <Icon name="zap" size="md" class="text-brand-500" />
              <p class="font-display text-2xl md:text-3xl font-bold text-brand-500">100</p>
              <p class="text-sm text-foreground-muted">Lighthouse Score</p>
            </div>
            <div class="bg-background-secondary rounded-xl p-5 flex flex-col items-center text-center gap-2 border-t-2 border-brand-500/40">
              <Icon name="timer" size="md" class="text-brand-500" />
              <p class="font-display text-2xl md:text-3xl font-bold text-brand-500">&lt;1s</p>
              <p class="text-sm text-foreground-muted">Page Load Time</p>
            </div>
            <div class="bg-background-secondary rounded-xl p-5 flex flex-col items-center text-center gap-2 border-t-2 border-brand-500/40">
              <Icon name="layout-grid" size="md" class="text-brand-500" />
              <p class="font-display text-2xl md:text-3xl font-bold text-brand-500">57+</p>
              <p class="text-sm text-foreground-muted">UI Components</p>
            </div>
            <div class="bg-background-secondary rounded-xl p-5 flex flex-col items-center text-center gap-2 border-t-2 border-brand-500/40">
              <Icon name="trending-down" size="md" class="text-brand-500" />
              <p class="font-display text-2xl md:text-3xl font-bold text-brand-500">0kb</p>
              <p class="text-sm text-foreground-muted">Zero JavaScript</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section id="work" class="pt-[var(--space-section-sm)] pb-[var(--space-section-lg)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <Badge variant="brand" pill class="mb-4">Selected Work</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Projects I've Built
        </h2>
        <p class="mt-4 text-lg text-foreground-muted max-w-2xl mx-auto">
          A selection of recent work.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Project 1 -->
        <Card variant="elevated" hover class="overflow-hidden !p-0">
          <div class="h-40 bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center">
            <Icon name="layout" size="xl" class="text-brand-500 opacity-40" />
          </div>
          <div class="p-6">
            <h3 class="font-semibold text-foreground mb-2">Project Name</h3>
            <p class="text-sm text-foreground-muted leading-relaxed mb-4">
              Short description of what you built and the outcome for the client.
            </p>
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">Astro</span>
              <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">Tailwind</span>
            </div>
            <a href="#" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors">
              View project <Icon name="arrow-right" size="sm" />
            </a>
          </div>
        </Card>

        <!-- Project 2 -->
        <Card variant="elevated" hover class="overflow-hidden !p-0">
          <div class="h-40 bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center">
            <Icon name="code" size="xl" class="text-brand-500 opacity-40" />
          </div>
          <div class="p-6">
            <h3 class="font-semibold text-foreground mb-2">Project Name</h3>
            <p class="text-sm text-foreground-muted leading-relaxed mb-4">
              Short description of what you built and the outcome for the client.
            </p>
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">Next.js</span>
              <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">TypeScript</span>
            </div>
            <a href="#" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors">
              View project <Icon name="arrow-right" size="sm" />
            </a>
          </div>
        </Card>

        <!-- Project 3 -->
        <Card variant="elevated" hover class="overflow-hidden !p-0">
          <div class="h-40 bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center">
            <Icon name="zap" size="xl" class="text-brand-500 opacity-40" />
          </div>
          <div class="p-6">
            <h3 class="font-semibold text-foreground mb-2">Project Name</h3>
            <p class="text-sm text-foreground-muted leading-relaxed mb-4">
              Short description of what you built and the outcome for the client.
            </p>
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">Astro</span>
              <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">CMS</span>
            </div>
            <a href="#" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors">
              View project <Icon name="arrow-right" size="sm" />
            </a>
          </div>
        </Card>

        <!-- Project 4 -->
        <Card variant="elevated" hover class="overflow-hidden !p-0">
          <div class="h-40 bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center">
            <Icon name="globe" size="xl" class="text-brand-500 opacity-40" />
          </div>
          <div class="p-6">
            <h3 class="font-semibold text-foreground mb-2">Project Name</h3>
            <p class="text-sm text-foreground-muted leading-relaxed mb-4">
              Short description of what you built and the outcome for the client.
            </p>
            <div class="flex flex-wrap gap-2 mb-4">
              <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">React</span>
              <span class="inline-flex items-center rounded-full bg-background-secondary px-2.5 py-0.5 text-xs font-medium text-foreground-muted ring-1 ring-inset ring-border">Node.js</span>
            </div>
            <a href="#" class="inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors">
              View project <Icon name="arrow-right" size="sm" />
            </a>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="pt-[var(--space-section-sm)] pb-[var(--space-section-lg)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <Badge variant="brand" pill class="mb-4">Testimonials</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          What Clients Say
        </h2>
        <p class="mt-4 text-lg text-foreground-muted">
          Real feedback from real projects.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Testimonial 1 -->
        <Card variant="elevated" padding="lg">
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed">
              "Astro Rocket cut our launch time in half. The design system is thoughtful, the Lighthouse scores are perfect out of the box, and the code is clean enough that we could customise everything without fighting the template."
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
                A
              </div>
              <div>
                <p class="text-sm font-semibold text-foreground">Alex Morgan</p>
                <p class="text-xs text-foreground-muted">Founder, Launchpad Studio</p>
              </div>
            </div>
          </div>
        </Card>

        <!-- Testimonial 2 -->
        <Card variant="elevated" padding="lg">
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed">
              "We switched from a custom Astro setup to Astro Rocket and never looked back. Dark mode, accessibility, blog — it's all there. What would have taken weeks was done in a day."
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
                B
              </div>
              <div>
                <p class="text-sm font-semibold text-foreground">Britta Hansen</p>
                <p class="text-xs text-foreground-muted">CEO, Nordvik Digital</p>
              </div>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section id="pricing" class="scroll-mt-20 pt-[var(--space-section-sm)] pb-[var(--space-section-lg)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <Badge variant="brand" pill class="mb-4">Free & Open Source</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Free for the community.
        </h2>
        <p class="mt-4 text-lg text-foreground-muted max-w-2xl mx-auto">
          MIT licensed. Clone it, build with it, ship it — no restrictions.
        </p>
      </div>

      <div class="mx-auto max-w-lg">
        <Card variant="elevated" padding="lg" class="relative overflow-hidden">
          <div class="absolute top-0 right-0 bg-brand-500 text-white text-xs font-bold px-4 py-1.5 rounded-bl-xl">
            MIT License
          </div>

          <div class="text-center mb-8">
            <h3 class="font-display text-2xl font-bold text-foreground mb-1 flex items-center justify-center gap-2">
              <Icon name="brand-astro" class="size-7 shrink-0" />Astro Rocket Theme
            </h3>
            <p class="text-sm text-foreground-muted mb-4">The Astro 6 starter that has everything</p>
            <div class="flex items-end justify-center gap-2">
              <span class="font-display text-6xl font-bold text-foreground">Free</span>
            </div>
          </div>

          <ul class="space-y-3 mb-8">
            {[
              'Astro 6 with full TypeScript support',
              '57+ ready-to-use components',
              '7 beautiful color themes',
              'Built-in dark mode',
              'i18n (multi-language) support',
              'Blog with MDX support',
              'SEO optimized out of the box',
              'MIT licensed — use it anywhere',
            ].map((feature) => (
              <li class="flex items-center gap-3 text-sm text-foreground-muted">
                <Icon name="check" size="sm" class="text-brand-500 shrink-0" />
                {feature}
              </li>
            ))}
          </ul>

          <Button size="lg" href="https://github.com/hansmartens68/astro-rocket" class="w-full justify-center">
            <Icon name="github" size="sm" />
            Get it on GitHub
            <Icon name="arrow-right" size="sm" />
          </Button>
          <p class="mt-3 text-center text-xs text-foreground-muted">
            No sign-up required · Clone and go
          </p>
        </Card>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="pt-[var(--space-section-sm)] pb-[var(--space-section-lg)] bg-background border-t border-border">
    <div class="mx-auto max-w-5xl px-6">
      <div class="text-center mb-[var(--space-section-header)]">
        <Badge variant="brand" pill class="mb-4">FAQ</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground flex items-center justify-center gap-3 flex-wrap">
          <Icon name="brand-astro" class="hidden md:inline-flex size-11 text-brand-500 shrink-0" />
          Questions about <span class="text-brand-500">Astro&nbsp;Rocket</span>?
        </h2>
        <p class="mt-4 text-lg text-foreground-muted max-w-xl mx-auto">
          Everything you need to know before you clone.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 md:gap-x-16">
        <!-- Column 1 -->
        <dl class="divide-y divide-border">
          {[
            {
              q: 'Do I need to know Astro to use this?',
              a: 'Basic HTML and JavaScript is enough to get started. Astro\'s syntax is close to plain HTML and the codebase is well-structured, so it\'s a great way to learn Astro in a real project. TypeScript is set up and ready but never forced on you.',
            },
            {
              q: 'How do the 7 color themes work?',
              a: 'Each theme is a set of CSS custom properties — switch themes by changing a single class on the html element. You can use any of the built-in themes as-is, tweak the values to match your brand, or build a completely new one in minutes.',
            },
            {
              q: 'Does it need a backend or database?',
              a: 'No. Astro Rocket is fully static by default — no server, no database, no runtime. Blog posts and content live in Markdown or MDX files. If you need dynamic data later, Astro\'s server and hybrid rendering modes make it straightforward to add.',
            },
          ].map(({ q, a }) => (
            <details class="group">
              <summary class="list-none [&::-webkit-details-marker]:hidden cursor-pointer flex items-center justify-between gap-4 py-5">
                <span class="font-display font-semibold text-foreground group-open:text-brand-500 transition-colors duration-150">{q}</span>
                <Icon name="chevron-down" size="sm" class="shrink-0 text-foreground-muted transition-transform duration-200 group-open:rotate-180" />
              </summary>
              <p class="pb-5 text-sm text-foreground-muted leading-relaxed">{a}</p>
            </details>
          ))}
        </dl>

        <!-- Column 2 -->
        <dl class="divide-y divide-border border-t border-border md:border-t-0">
          {[
            {
              q: 'Can I use React or Vue components inside it?',
              a: 'Yes. Astro\'s island architecture lets you drop in React, Vue, Svelte, or Solid components anywhere you need interactivity. The rest of the page stays as zero-JS static HTML, so performance is never compromised by a single interactive widget.',
            },
            {
              q: 'How does the i18n support work?',
              a: 'Routing, content collections, and UI strings are all locale-aware out of the box. Add a new language by creating a folder and a translation file — no third-party library required. The blog and all pages support multiple languages without any changes to the component layer.',
            },
            {
              q: 'Where do I deploy it and how hard is that?',
              a: 'One command. Astro Rocket is optimised for Vercel and Netlify — connect your repo, set the build command to `astro build`, and you\'re live. It also works on any static host (GitHub Pages, Cloudflare Pages, S3) or as a server-rendered app on Node.js.',
            },
          ].map(({ q, a }) => (
            <details class="group">
              <summary class="list-none [&::-webkit-details-marker]:hidden cursor-pointer flex items-center justify-between gap-4 py-5">
                <span class="font-display font-semibold text-foreground group-open:text-brand-500 transition-colors duration-150">{q}</span>
                <Icon name="chevron-down" size="sm" class="shrink-0 text-foreground-muted transition-transform duration-200 group-open:rotate-180" />
              </summary>
              <p class="pb-5 text-sm text-foreground-muted leading-relaxed">{a}</p>
            </details>
          ))}
        </dl>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section class="pt-[var(--space-section-sm)] pb-[var(--space-section-lg)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex items-end justify-between mb-[var(--space-section-header)]">
        <div>
          <Badge variant="brand" pill class="mb-4">From the blog</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Latest posts
          </h2>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors shrink-0">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id.replace('en/', '')}`}
            publishedAt={post.data.publishedAt}
            tags={post.data.tags}
            featured={post.data.featured}
            author={post.data.author}
            image={post.data.image}
          />
        ))}
      </div>

      <div class="mt-8 text-center sm:hidden">
        <Button variant="outline" href="/blog">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTA variant="invert" size="md" maxWidth="lg">
    <Badge slot="logo" variant="brand" pill>Get Started</Badge>
    <h2 slot="heading">Ready to start building?</h2>
    <p slot="description" class="!text-lg">
      Clone Astro Rocket and have a production-ready site running in minutes.
    </p>
    <div slot="actions" class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button size="lg" href="https://github.com/hansmartens68/astro-rocket">
        <Icon name="github" size="sm" />
        Get it on GitHub
      </Button>
      <Button size="lg" variant="outline" href="/about">
        Explore the Theme
      </Button>
    </div>
  </CTA>
</LandingLayout>
