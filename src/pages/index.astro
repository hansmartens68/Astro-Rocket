---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import CTA from '@/components/ui/marketing/CTA/CTA.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import { getCollection } from 'astro:content';

const projectItems = await getCollection('projects');
const featuredProjects = projectItems
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 4);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);
---

<LandingLayout
  title="Web Designer & Developer | Veghel"
  description="Web designer and developer based in Veghel, the Netherlands. Crafting modern web experiences shaped by clean design, solid structure, and attention to detail.

    </p>"
  image="/og-homepage.jpeg"
  includePersonSchema={true}
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="centered" size="xl">
    <Badge slot="badge" variant="brand" pill pulse>Available for new projects</Badge>

    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">Hans Martens —</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">Web Designer</span><span class="text-foreground [-webkit-text-fill-color:currentColor]"> &amp; Developer</span>
    </h1>

    <p slot="description">
      Crafting modern web experiences shaped by clean design, solid structure, and attention to detail.
    </p>

   <Fragment slot="actions">
      <Button size="lg" href="https://github.com">
        <Icon name="github" size="sm" />
        Get it on GitHub
      </Button>
      <Button size="lg" variant="outline" href="/about">
        Learn more
         <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>
  </Hero>

  <!-- Services Section -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Services</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          What I do
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          From concept to launch.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" data-reveal data-reveal-delay="1">
        <!-- Web Design -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="layout" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Web Design</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Clean, modern interfaces that look great on every screen. Focused on clarity, usability, and your brand identity.
              </p>
            </div>
          </div>
        </Card>

        <!-- Web Development -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="code" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Web Development</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Fast, accessible websites built with modern tooling. Astro, Tailwind, and best-practice architecture from day one.
              </p>
            </div>
          </div>
        </Card>

        <!-- Performance -->
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="zap" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Performance Optimization</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Core Web Vitals, SEO, and page speed — built in from the start, not bolted on at the end.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

 <!-- About Teaser -->
  <section class="py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div>
          <Badge variant="brand" pill class="mb-4">About me</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground mb-6">
            Designer, developer,<br />
            <span class="text-brand-500">and blogger.</span>
          </h2>
          <p class="text-lg text-foreground-muted leading-relaxed mb-4">
           I'm particular about the things most clients overlook — page speed, accessibility, and whether the design actually serves the content. That attention to detail is what I bring to every project.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed mb-8">
           Whether you're a business looking for a polished online presence, or a creator who needs a site that matches your ambitions — I'd love to help.
          </p>
          <Button variant="outline" href="/about">
            More About Me
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="1">
          <p class="font-semibold text-sm text-foreground text-center">Hans Martens — by the numbers</p>
          <p class="text-sm text-foreground-muted mt-0.5 mb-5 text-center">A few things about me.</p>
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center text-center gap-2 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default">
              <Icon name="history" size="md" class="text-brand-500" />
              <p class="font-display text-2xl md:text-3xl font-bold text-brand-500" data-countup="16" data-suffix="+">16+</p>
              <p class="text-sm text-foreground-muted">Years Experience</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center text-center gap-2 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default">
              <Icon name="check-circle" size="md" class="text-brand-500" />
              <p class="font-display text-2xl md:text-3xl font-bold text-brand-500" data-countup="50" data-suffix="+">50+</p>
              <p class="text-sm text-foreground-muted">Projects Delivered</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center text-center gap-2 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default">
              <Icon name="globe" size="md" class="text-brand-500" />
              <p class="font-display text-2xl md:text-3xl font-bold text-brand-500" data-countup="25" data-suffix="+">25+</p>
              <p class="text-sm text-foreground-muted">Worldwide Clients</p>
            </div>
            <div class="bg-background-tertiary rounded-xl p-5 flex flex-col items-center text-center gap-2 border-t-2 border-brand-500/40 transition-all duration-200 hover:-translate-y-1 hover:shadow-md hover:border-brand-500 cursor-default">
              <Icon name="map-pin" size="md" class="text-brand-500" />
              <p class="font-display text-2xl md:text-3xl font-bold text-brand-500">NL</p>
              <p class="text-sm text-foreground-muted">Based in Veghel</p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section id="work" class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Selected work</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Projects I've built
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          A selection of recent work.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2" data-reveal data-reveal-delay="1">
        {featuredProjects.map((project) => (
          <Card variant="elevated" hover padding="lg" href={project.data.url ?? project.data.repo} target="_blank" rel="noopener noreferrer" class="group flex flex-col">
            <div class="flex flex-1 flex-col">
              <div class="mb-3 flex items-start justify-between gap-4">
                <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="layers" size="sm" />
                </div>
                <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
              </div>
              <div class="mb-2 flex items-baseline gap-2">
                <h3 class="font-display text-lg font-bold text-foreground">{project.data.title}</h3>
                {project.data.year && (
                  <span class="text-xs text-foreground-muted">{project.data.year}</span>
                )}
              </div>
              <p class="text-sm text-foreground-muted leading-relaxed mb-4 flex-1">{project.data.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.map((tag) => (
                  <Badge variant="brand">{tag}</Badge>
                ))}
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Testimonials</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          What clients say
        </h2>
        <p class="text-lg text-foreground-muted">
          Real feedback from real projects.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2" data-reveal data-reveal-delay="1">
        <!-- Testimonial 1 -->
        <Card variant="elevated" padding="lg" hover>
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed">
              "Replace this with a real quote from a client. Something specific about the results they got or the experience of working with you."
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
                A
              </div>
              <div>
                <p class="text-sm font-semibold text-foreground">Client Name</p>
                <p class="text-xs text-foreground-muted">Founder, Company Name</p>
              </div>
            </div>
          </div>
        </Card>

        <!-- Testimonial 2 -->
        <Card variant="elevated" padding="lg" hover>
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed">
              "Replace this with a real quote from a client. Something specific about the results they got or the experience of working with you."
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">
                B
              </div>
              <div>
                <p class="text-sm font-semibold text-foreground">Client Name</p>
                <p class="text-xs text-foreground-muted">CEO, Company Name</p>
              </div>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex items-end justify-between" data-reveal>
        <div class="flex flex-col gap-4">
          <Badge variant="brand" pill class="self-start">From the blog</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Featured
          </h2>
        </div>
        <a href="/blog" class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-brand-500 hover:text-brand-600 transition-colors shrink-0">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3" data-reveal data-reveal-delay="1">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            href={`/blog/${post.id.replace('en/', '')}`}
            publishedAt={post.data.publishedAt}
            tags={post.data.tags}
            featured={post.data.featured}
            author={post.data.author}
            image={post.data.image}
            svgSlug={post.data.svgSlug}
          />
        ))}
      </div>

      <div class="text-center sm:hidden">
        <Button variant="outline" href="/blog">
          View all posts
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

 <!-- CTA -->
  <CTA variant="invert" size="md" maxWidth="lg">
    <h2 slot="heading">Let's build something together</h2>
    <p slot="description" class="!text-lg">
      Get in touch. Response within 1 day.
    </p>
    <Fragment slot="actions">
      <Button size="lg" href="/contact" class="hero-btn-brand">
        Start a project
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" href="/about" class="hero-btn-learn">
        More about me
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>
  </CTA>


<script>
  const counters = document.querySelectorAll<HTMLElement>('[data-countup]');
  if (counters.length > 0) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        observer.unobserve(entry.target);
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.countup ?? '0', 10);
        const suffix = el.dataset.suffix ?? '';
        const duration = 1200;
        const start = performance.now();
        const tick = (now: number) => {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          el.textContent = Math.round(eased * target) + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.4 });
    counters.forEach((el) => observer.observe(el));
  }
</script>
</LandingLayout>
