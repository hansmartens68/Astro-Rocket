---
const svgs = import.meta.glob<string>('/src/assets/blog/*.svg', { as: 'raw', eager: true });

interface Props {
  slug: string;
  title: string;
}

const { slug, title } = Astro.props;
const svgContent = svgs[`/src/assets/blog/${slug}.svg`] ?? '';
---

{svgContent && (
  <div class="svg-host" role="img" aria-label={title} set:html={svgContent} />
)}

<style>
  .svg-host :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (min-width: 640px) {
    .svg-host :global(svg) {
      transform: scale(1.35);
      transform-origin: center center;
    }
  }

  /* Light mode: use a deeper brand tone for the image background. */
  .svg-host :global(.bg) {
    fill: var(--brand-800);
  }

  /* Dark mode: shift background darker so the image recedes into the page
     rather than glowing against the near-black surface. */
  :global(html.dark) .svg-host :global(.bg) {
    fill: var(--brand-800);
  }

  :global(html.dark) .svg-host :global(.ln),
  :global(html.dark) .svg-host :global(.cor) {
    stroke-opacity: 0.25;
  }

  :global(html.dark) .svg-host :global(.pil) {
    fill-opacity: 0.15;
    stroke-opacity: 0.3;
  }
</style>
