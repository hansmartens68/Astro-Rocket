---
const svgs = import.meta.glob<string>('/src/assets/blog/*.svg', { as: 'raw', eager: true });

interface Props {
  slug: string;
  title: string;
}

const { slug, title } = Astro.props;
const svgContent = svgs[`/src/assets/blog/${slug}.svg`] ?? '';
---

{svgContent && (
  <div class="svg-host" role="img" aria-label={title} set:html={svgContent} />
)}

<style>
  .svg-host :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (min-width: 640px) {
    .svg-host :global(svg) {
      transform: scale(1.35);
      transform-origin: center center;
    }
  }

  /* Dark mode: shift background one step lighter (brand-400) to compensate
     for the perceptual luminance drop against a near-black page surface. */
  :global(html.dark) .svg-host :global(.bg) {
    fill: var(--brand-400);
  }

  :global(html.dark) .svg-host :global(.ln),
  :global(html.dark) .svg-host :global(.cor) {
    stroke-opacity: 0.55;
  }

  :global(html.dark) .svg-host :global(.pil) {
    fill-opacity: 0.35;
    stroke-opacity: 0.6;
  }
</style>
