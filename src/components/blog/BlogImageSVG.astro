---
const svgs = import.meta.glob<string>('/src/assets/blog/*.svg', { as: 'raw', eager: true });

interface Props {
  slug: string;
  title: string;
}

const { slug, title } = Astro.props;
const svgContent = svgs[`/src/assets/blog/${slug}.svg`] ?? '';
---

{svgContent && (
  <div class="svg-host" role="img" aria-label={title} set:html={svgContent} />
)}

<style>
  .svg-host :global(svg) {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Dark elements hidden by default (light mode) ── */
  .svg-host :global(.bi-bg-d),
  .svg-host :global(.bi-gd),
  .svg-host :global(.bi-ibd) {
    display: none;
  }

  /* ── Dark mode: swap light ↔ dark layers ── */
  :global(.dark) .svg-host :global(.bi-bg-l),
  :global(.dark) .svg-host :global(.bi-gl),
  :global(.dark) .svg-host :global(.bi-ibl) {
    display: none;
  }
  :global(.dark) .svg-host :global(.bi-bg-d),
  :global(.dark) .svg-host :global(.bi-gd),
  :global(.dark) .svg-host :global(.bi-ibd) {
    display: block;
  }

  /* ── Icon stroke ── */
  .svg-host :global(.bi-icon) { stroke: #3d6b0c; }
  :global(.dark) .svg-host :global(.bi-icon) { stroke: #a3e635; }

  /* ── Title text ── */
  .svg-host :global(.bi-title) { fill: #0c1a2e; }
  :global(.dark) .svg-host :global(.bi-title) { fill: #f0fce5; }

  /* ── Separator line ── */
  .svg-host :global(.bi-sep) { stroke: rgba(132, 204, 22, 0.45); }
  :global(.dark) .svg-host :global(.bi-sep) { stroke: rgba(163, 230, 53, 0.2); }

  /* ── Badge background ── */
  .svg-host :global(.bi-badge) {
    fill: rgba(132, 204, 22, 0.1);
    stroke: rgba(84, 163, 10, 0.45);
  }
  :global(.dark) .svg-host :global(.bi-badge) {
    fill: rgba(163, 230, 53, 0.08);
    stroke: rgba(163, 230, 53, 0.3);
  }

  /* ── Badge text ── */
  .svg-host :global(.bi-badge-text) { fill: #3f6212; }
  :global(.dark) .svg-host :global(.bi-badge-text) { fill: #a3e635; }

  /* ── Corners & rings – always lime ── */
  .svg-host :global(.bi-corner) { stroke: #84cc16; }
  .svg-host :global(.bi-ring)   { stroke: #84cc16; }
</style>
