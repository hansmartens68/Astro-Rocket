---
/**
 * Logo Component — Astro Rocket badge
 *
 * Renders a brand-coloured square badge with a rocket icon that scales with
 * the size prop, used in the navbar, footer, and blog post bylines.
 */
import { cn } from '@/lib/cn';
import siteConfig from '@/config/site.config';

interface Props {
  /** Size preset */
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  /** Force dark mode logo (for dark backgrounds) — no-op here, kept for API compat */
  forceDark?: boolean;
  /** Use full logo instead of logomark — no-op here, kept for API compat */
  variant?: 'logomark' | 'full';
  /** Additional CSS classes */
  class?: string;
}

const {
  size = 'md',
  class: className,
} = Astro.props;

const sizeClasses: Record<string, { box: string; icon: string; radius: string }> = {
  sm:    { box: 'w-5 h-5',    icon: 'w-3 h-3',     radius: 'rounded-[4px]' },
  md:    { box: 'w-6 h-6',    icon: 'w-3.5 h-3.5', radius: 'rounded-[5px]' },
  lg:    { box: 'w-8 h-8',    icon: 'w-5 h-5',     radius: 'rounded-[6px]' },
  xl:    { box: 'w-12 h-12',  icon: 'w-7 h-7',     radius: 'rounded-[8px]' },
  '2xl': { box: 'w-24 h-24',  icon: 'w-14 h-14',   radius: 'rounded-[14px]' },
};

const { box, icon, radius } = sizeClasses[size] ?? sizeClasses.md;
---

<span
  class={cn(
    'inline-flex items-center justify-center shrink-0',
    'bg-brand-500 text-white',
    'select-none',
    box, radius,
    className
  )}
  aria-label={siteConfig.branding.logo.alt}
  role="img"
>
  <svg
    class={icon}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
    <path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
    <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" />
    <path d="M15 12v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
  </svg>
</span>
