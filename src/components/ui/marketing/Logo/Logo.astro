---
/**
 * Logo Component — letter badge or official Astro logo
 *
 * Controlled by `branding.logoStyle` in site.config.ts:
 *   'badge'  — auto-generated letter badge (default, portable, works for any site)
 *   'svg'    — renders the official Astro logo
 *
 * When logoStyle is 'svg':
 *   variant='logomark'  — Astro icon as inline SVG (default; used in navbar/footer)
 *                         Automatically uses the brand color in light mode and white
 *                         on dark/inverted backgrounds — no hardcoded colors.
 *   variant='full'      — horizontal wordmark SVG from src/assets/branding/
 *   forceDark           — forces white logo (for dark/inverted backgrounds)
 *
 * To switch back to the badge for your own site:
 *   Set `logoStyle: 'badge'` in site.config.ts
 */
import { Image } from 'astro:assets';
import { cn } from '@/lib/cn';
import siteConfig from '@/config/site.config';
import logoFullLight from '@/assets/branding/logo-full.svg';
import logoFullDark from '@/assets/branding/logo-full-dark.svg';

// Official Astro logo path — Simple Icons (CC0 1.0 public domain), viewBox 0 0 24 24
const ASTRO_LOGO_PATH =
  'M8.358 20.162c-1.186-1.07-1.532-3.316-1.038-4.944.856 1.026 2.043 1.352 3.272 1.535 1.897.283 3.76.177 5.522-.678.202-.098.388-.229.608-.36.166.473.209.95.151 1.437-.14 1.185-.738 2.1-1.688 2.794-.38.277-.782.525-1.175.787-1.205.804-1.531 1.747-1.078 3.119l.044.148a3.158 3.158 0 0 1-1.407-1.188 3.31 3.31 0 0 1-.544-1.815c-.004-.32-.004-.642-.048-.958-.106-.769-.472-1.113-1.161-1.133-.707-.02-1.267.411-1.415 1.09-.012.053-.028.104-.045.165h.002zm-5.961-4.445s3.24-1.575 6.49-1.575l2.451-7.565c.092-.366.36-.614.662-.614.302 0 .57.248.662.614l2.45 7.565c3.85 0 6.491 1.575 6.491 1.575L16.088.727C15.93.285 15.663 0 15.303 0H8.697c-.36 0-.615.285-.784.727l-5.516 14.99z';

interface Props {
  /** Size preset */
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  /** Force white logo (for dark/inverted backgrounds) */
  forceDark?: boolean;
  /** 'logomark' = Astro icon, 'full' = horizontal wordmark */
  variant?: 'logomark' | 'full';
  /** Additional CSS classes */
  class?: string;
}

const {
  size = 'md',
  forceDark = false,
  variant = 'logomark',
  class: className,
} = Astro.props;

const logoStyle = siteConfig.branding.logoStyle ?? 'badge';

// Badge sizes
const sizeClasses: Record<string, { box: string; text: string; radius: string }> = {
  sm:    { box: 'w-5 h-5',   text: 'text-[14px]', radius: 'rounded-[4px]' },
  md:    { box: 'w-6 h-6',   text: 'text-[16px]', radius: 'rounded-[5px]' },
  lg:    { box: 'w-8 h-8',   text: 'text-[22px]', radius: 'rounded-[6px]' },
  xl:    { box: 'w-12 h-12', text: 'text-[34px]', radius: 'rounded-[8px]' },
  '2xl': { box: 'w-24 h-24', text: 'text-[68px]', radius: 'rounded-[14px]' },
};

// SVG height — CSS handles scaling, w-auto keeps aspect ratio
const svgHeights: Record<string, string> = {
  sm:    'h-5',
  md:    'h-6',
  lg:    'h-8',
  xl:    'h-12',
  '2xl': 'h-24',
};

const { box, text, radius } = sizeClasses[size] ?? sizeClasses.md;
const heightClass = svgHeights[size] ?? svgHeights.md;
const letter = siteConfig.name.charAt(0).toUpperCase();
const alt = siteConfig.branding.logo.alt;
const isFull = variant === 'full';
---

{logoStyle === 'svg' ? (
  isFull ? (
    // Full wordmark — uses SVG files from src/assets/branding/
    forceDark ? (
      <Image src={logoFullDark} alt={alt} class={cn(heightClass, 'w-auto shrink-0', className)} />
    ) : (
      <>
        <Image src={logoFullLight} alt={alt} class={cn(heightClass, 'w-auto shrink-0 dark:hidden', className)} />
        <Image src={logoFullDark} alt={alt} class={cn(heightClass, 'w-auto shrink-0 hidden dark:block', className)} />
      </>
    )
  ) : (
    // Logomark — official Astro logo as inline SVG, color via currentColor
    // Light mode: brand color. Dark mode / inverted header: white.
    <svg
      viewBox="0 0 24 24"
      fill="currentColor"
      class={cn(
        heightClass, 'w-auto shrink-0',
        forceDark ? 'text-white' : 'text-brand-500 dark:text-white',
        className
      )}
      role="img"
      aria-label={alt}
    >
      <path d={ASTRO_LOGO_PATH} />
    </svg>
  )
) : (
  // Badge — auto-generated letter, no external assets needed
  <span
    class={cn(
      'inline-flex items-center justify-center shrink-0',
      'bg-brand-500 text-white',
      'font-display font-bold leading-none select-none',
      box, text, radius,
      className
    )}
    aria-label={alt}
    role="img"
  >
    {letter}
  </span>
)}
