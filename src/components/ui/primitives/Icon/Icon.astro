<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox={viewBox}
  fill={isBrand ? 'currentColor' : 'none'}
  stroke={isBrand ? 'none' : 'currentColor'}
  stroke-width={isBrand ? 0 : strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cn(sizes[size], 'shrink-0', className)}
  aria-hidden="true"
>
  {isBrand ? (
    <path d={iconPath} />
  ) : (
    iconPath.split('M').filter(Boolean).map((d) => (
      <path d={`M${d}`} />
    ))
  )}
</svg>
