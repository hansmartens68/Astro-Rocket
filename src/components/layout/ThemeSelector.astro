---
/**
 * ThemeSelector
 * A row of five colour swatches that switches the active colour theme at
 * runtime by writing `data-theme` on <html> and persisting to localStorage.
 *
 * Usage in Header:  <ThemeSelector />
 * Pass `class` to tint the label colour for floating / inverted headers.
 */
interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const themes = [
  { id: 'aurora',   name: 'Aurora',   color: 'oklch(58% 0.27 278)'   },
  { id: 'midnight', name: 'Midnight', color: 'oklch(58% 0.25 295)'   },
  { id: 'studio',   name: 'Studio',   color: 'oklch(62.5% 0.22 255)' },
  { id: 'verdant',  name: 'Verdant',  color: 'oklch(62.5% 0.22 155)' },
  { id: 'default',  name: 'Default',  color: 'oklch(62.5% 0.22 38)'  },
];
---

<div
  class:list={['theme-selector flex items-center gap-1.5', className]}
  role="group"
  aria-label="Select colour theme"
>
  {themes.map((theme) => (
    <button
      type="button"
      class="theme-swatch relative h-[18px] w-[18px] rounded-full transition-transform duration-150 focus-visible:outline-none"
      data-theme-id={theme.id}
      style={`background-color:${theme.color};--swatch:${theme.color}`}
      title={theme.name}
      aria-label={`${theme.name} theme`}
    />
  ))}
</div>

<style>
  /* Inactive: subtle border so light swatches are visible on light bg */
  .theme-swatch {
    box-shadow: inset 0 0 0 1px oklch(0% 0 0 / 0.12);
  }

  /* Active: double-ring using the swatch's own colour */
  .theme-swatch[data-active] {
    box-shadow:
      0 0 0 2px var(--color-background),
      0 0 0 4px var(--swatch);
    transform: scale(1.2);
  }

  /* Hover */
  .theme-swatch:not([data-active]):hover {
    transform: scale(1.15);
  }
</style>

<script>
  const STORAGE_KEY = 'color-theme';
  const DEFAULT_THEME = 'aurora';

  function getActiveTheme(): string {
    try {
      return localStorage.getItem(STORAGE_KEY) || DEFAULT_THEME;
    } catch {
      return DEFAULT_THEME;
    }
  }

  function setTheme(id: string) {
    document.documentElement.setAttribute('data-theme', id);
    try { localStorage.setItem(STORAGE_KEY, id); } catch { /* private mode */ }

    // Update every swatch on the page (handles multiple selector instances)
    document.querySelectorAll<HTMLButtonElement>('.theme-swatch').forEach((btn) => {
      btn.dataset.themeId === id
        ? btn.setAttribute('data-active', '')
        : btn.removeAttribute('data-active');
    });
  }

  function initThemeSelector() {
    const active = getActiveTheme();

    document.querySelectorAll<HTMLButtonElement>('.theme-swatch').forEach((btn) => {
      // Mark current active
      btn.dataset.themeId === active
        ? btn.setAttribute('data-active', '')
        : btn.removeAttribute('data-active');

      // Guard against double-binding across re-runs
      if (btn.dataset.selectorInit) return;
      btn.dataset.selectorInit = 'true';

      btn.addEventListener('click', () => setTheme(btn.dataset.themeId!));
    });
  }

  initThemeSelector();
  document.addEventListener('astro:page-load', initThemeSelector);
  document.addEventListener('astro:after-swap', initThemeSelector);
</script>
